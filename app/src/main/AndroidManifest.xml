<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SiLaut">
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:label="Login siLaut"
            android:theme="@style/Theme.SiLaut">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:label="Daftar siLaut" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.SiLaut" />

        <activity
            android:name=".ui.pengaduan.BuatPengaduanActivity"
            android:exported="false"
            android:label="Buat Pengaduan"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:label="Live Chat siLaut"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.pengaduan.StatusLaporanActivity_018"
            android:exported="false"
            android:label="Status Laporan siLaut" />

        <activity
            android:name=".ui.admin.AdminMainActivity_018"
            android:exported="false"
            android:label="Panel Admin siLaut" />

        <activity
            android:name=".ui.admin.AdminChatListActivity_018"
            android:exported="false"
            android:label="Pesan Masuk" />
    </application>

</manifest>